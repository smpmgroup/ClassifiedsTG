generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum UserStatus {
  active
  restricted
  banned
  deleted
}
enum MemberRole {
  member
  moderator
  admin
  owner
}
enum MembershipStatus {
  creator
  administrator
  member
  restricted
  left
  kicked
  unknown
}
enum ListingStatus {
  draft
  pending
  changes_requested
  published
  rejected
  sold
  archived
  expired
  hidden
  deleted
}
enum PriceType {
  fixed
  negotiable
  free
  exchange
  contact
}
enum ItemCondition {
  new
  like_new
  good
  fair
  for_parts
  not_applicable
}
enum ReportStatus {
  open
  reviewing
  resolved
  dismissed
}
enum NotificationStatus {
  pending
  processing
  sent
  failed
}
enum PlatformRole {
  user
  support
  finance
  platform_admin
  platform_owner
}
enum OrganizationRole {
  member
  administrator
  owner
}
enum TenantStatus {
  onboarding
  active
  suspended
  closed
}

model Community {
  id String @id @default(cuid())
  telegramChatId BigInt @unique
  name String
  slug String @unique
  organizationId String?
  tenantStatus TenantStatus @default(active)
  connectedAt DateTime?
  disconnectedAt DateTime?
  suspendedAt DateTime?
  botStatus String @default("unknown")
  botIsAdministrator Boolean @default(false)
  botCanDeleteMessages Boolean @default(false)
  botCanRestrictMembers Boolean @default(false)
  botCanInviteUsers Boolean @default(false)
  botLastCheckedAt DateTime?
  deletionRequestedAt DateTime?
  deletionScheduledFor DateTime?
  deletionFinalizedAt DateTime?
  deletionRequestedById String?
  description String @default("")
  inviteUrl String
  isActive Boolean @default(true)
  moderationEnabled Boolean @default(true)
  remoderatePublishedEdits Boolean @default(true)
  autoPublishEnabled Boolean @default(false)
  publicationMode String @default("none")
  publicationChatId BigInt?
  publicationThreadId Int?
  defaultCurrency String @default("EUR")
  defaultLocale String @default("ru")
  maxActiveListingsPerUser Int @default(10)
  maxImagesPerListing Int @default(10)
  listingLifetimeDays Int @default(45)
  autoHideReportThreshold Int @default(3)
  rules String @default("")
  prohibitedWords String[] @default([])
  minMonthlyMessagesForFree Int @default(10)
  publicationPriceStars Int @default(50)
  allowPaidNonMembers Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members CommunityMember[]
  categories Category[]
  listings Listing[]
  reports Report[]
  actions ModerationAction[]
  notifications Notification[]
  activities MessageActivity[]
  payments PublicationPayment[]
  organization Organization? @relation(fields: [organizationId], references: [id])
  auditEvents AuditEvent[]
  ledgerTransactions LedgerTransaction[]
  supportTickets SupportTicket[]
  @@index([organizationId, tenantStatus])
}

model User {
  id String @id @default(cuid())
  telegramUserId BigInt @unique
  username String?
  firstName String
  lastName String?
  languageCode String?
  photoUrl String?
  status UserStatus @default(active)
  platformRole PlatformRole @default(user)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastSeenAt DateTime @default(now())
  botStartedAt DateTime?
  members CommunityMember[]
  listings Listing[] @relation("ListingAuthor")
  moderatedListings Listing[] @relation("ListingModerator")
  favorites Favorite[]
  reports Report[] @relation("Reporter")
  reviewedReports Report[] @relation("ReportReviewer")
  actions ModerationAction[] @relation("Moderator")
  targetedActions ModerationAction[] @relation("TargetUser")
  notifications Notification[]
  views ListingView[]
  activities MessageActivity[]
  payments PublicationPayment[]
  organizations OrganizationMember[]
  auditEvents AuditEvent[] @relation("AuditActor")
  connectionIntents CommunityConnectionIntent[]
  supportTicketsCreated SupportTicket[] @relation("SupportTicketCreator")
  supportTicketsAssigned SupportTicket[] @relation("SupportTicketAssignee")
  supportMessages SupportMessage[]
}

model Organization {
  id String @id @default(cuid())
  name String
  slug String @unique
  legalName String?
  billingEmail String?
  stripeCustomerId String? @unique
  stripeConnectAccountId String? @unique
  stripeSubscriptionId String? @unique
  subscriptionStatus String @default("none")
  subscriptionPlanKey String?
  subscriptionPriceId String?
  subscriptionCurrentPeriodEnd DateTime?
  subscriptionCancelAtPeriodEnd Boolean @default(false)
  billingUpdatedAt DateTime?
  connectDetailsSubmitted Boolean @default(false)
  connectChargesEnabled Boolean @default(false)
  connectPayoutsEnabled Boolean @default(false)
  connectRequirementsDue String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  communities Community[]
  members OrganizationMember[]
  connectionIntents CommunityConnectionIntent[]
  ledgerAccounts LedgerAccount[]
  ledgerTransactions LedgerTransaction[]
  supportTickets SupportTicket[]
  stripeInvoices StripeInvoiceRecord[]
}

model BillingPlan {
  id String @id @default(cuid())
  key String @unique
  name String
  description String @default("")
  stripePriceId String? @unique
  currency String @default("eur")
  unitAmount Int @default(0)
  interval String @default("month")
  features Json @default("[]")
  active Boolean @default(true)
  sortOrder Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StripeWebhookEvent {
  id String @id
  type String
  livemode Boolean
  status String @default("processing")
  attempts Int @default(1)
  payload Json
  lastError String?
  processedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([status, createdAt])
  @@index([type, createdAt])
}

model StripeInvoiceRecord {
  id String @id
  organizationId String
  subscriptionId String?
  status String
  currency String
  amountDue Int
  amountPaid Int
  hostedInvoiceUrl String?
  periodStart DateTime?
  periodEnd DateTime?
  createdAt DateTime
  updatedAt DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  @@index([organizationId, createdAt])
  @@index([subscriptionId, status])
}

model SupportTicket {
  id String @id @default(cuid())
  organizationId String
  communityId String?
  createdById String
  assignedToId String?
  subject String
  status String @default("open")
  priority String @default("normal")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resolvedAt DateTime?
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  community Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  createdBy User @relation("SupportTicketCreator", fields: [createdById], references: [id])
  assignedTo User? @relation("SupportTicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages SupportMessage[]
  @@index([organizationId, status, updatedAt])
  @@index([status, priority, updatedAt])
}

model SupportMessage {
  id String @id @default(cuid())
  ticketId String
  authorId String
  body String
  internal Boolean @default(false)
  createdAt DateTime @default(now())
  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])
  @@index([ticketId, createdAt])
}

model OrganizationMember {
  id String @id @default(cuid())
  organizationId String
  userId String
  role OrganizationRole @default(member)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([organizationId, userId])
  @@index([userId, role])
}

model PlatformSetting {
  id String @id @default("global")
  platformName String @default("Community Board")
  minimumPublicationStars Int @default(10)
  defaultCommissionBps Int @default(2500)
  payoutsEnabled Boolean @default(false)
  starsHoldDays Int @default(21)
  minimumPayoutStars Int @default(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditEvent {
  id String @id @default(cuid())
  communityId String?
  actorId String?
  scope String
  action String
  targetType String?
  targetId String?
  metadata Json @default("{}")
  ipHash String?
  createdAt DateTime @default(now())
  community Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  @@index([communityId, createdAt])
  @@index([actorId, createdAt])
  @@index([scope, action, createdAt])
}

model CommunityConnectionIntent {
  id String @id @default(cuid())
  tokenHash String @unique
  organizationId String
  requestedById String
  status String @default("pending")
  expiresAt DateTime
  claimedChatId BigInt?
  communityId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedBy User @relation(fields: [requestedById], references: [id], onDelete: Cascade)
  @@index([requestedById, status, expiresAt])
  @@index([organizationId, status])
}

model CommunityMember {
  id String @id @default(cuid())
  communityId String
  userId String
  role MemberRole @default(member)
  telegramMembershipStatus MembershipStatus @default(unknown)
  membershipCheckedAt DateTime?
  isMuted Boolean @default(false)
  mutedUntil DateTime?
  notifyListingUpdates Boolean @default(true)
  notifyBuyerInterest Boolean @default(true)
  allowDirectContact Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([communityId, userId])
  @@index([communityId, role])
}

model Category {
  id String @id @default(cuid())
  communityId String
  parentId String?
  name String
  slug String
  icon String?
  sortOrder Int @default(0)
  isActive Boolean @default(true)
  fieldSchema Json @default("[]")
  conditionEnabled Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  parent Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  listings Listing[]
  @@unique([communityId, slug])
}

model Listing {
  id String @id @default(cuid())
  legacyId String? @unique
  communityId String
  authorId String
  categoryId String
  title String
  description String
  price Decimal? @db.Decimal(14, 2)
  currency String @default("EUR")
  priceType PriceType @default(fixed)
  condition ItemCondition @default(good)
  locationText String?
  latitude Decimal? @db.Decimal(9, 6)
  longitude Decimal? @db.Decimal(9, 6)
  contactMode String @default("telegram")
  status ListingStatus @default(draft)
  moderationComment String?
  moderatedById String?
  moderatedAt DateTime?
  publishedAt DateTime?
  expiresAt DateTime?
  soldAt DateTime?
  viewCount Int @default(0)
  favoritesCount Int @default(0)
  duplicateSuspected Boolean @default(false)
  attributes Json @default("{}")
  paymentStatus String @default("not_required")
  publicationMessageId Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author User @relation("ListingAuthor", fields: [authorId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
  moderatedBy User? @relation("ListingModerator", fields: [moderatedById], references: [id])
  images ListingImage[]
  favorites Favorite[]
  reports Report[]
  actions ModerationAction[]
  views ListingView[]
  payment PublicationPayment?
  @@index([communityId, status, publishedAt])
  @@index([authorId, status])
}

model MessageActivity {
  id String @id @default(cuid())
  communityId String
  userId String
  month String
  messageCount Int @default(0)
  updatedAt DateTime @updatedAt
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([communityId, userId, month])
}

model PublicationPayment {
  id String @id @default(cuid())
  communityId String
  userId String
  listingId String @unique
  amountStars Int
  commissionBps Int @default(2500)
  platformFeeStars Int @default(0)
  communityShareStars Int @default(0)
  invoicePayload String @unique
  telegramPaymentChargeId String? @unique
  status String @default("pending")
  createdAt DateTime @default(now())
  paidAt DateTime?
  community Community @relation(fields: [communityId], references: [id])
  user User @relation(fields: [userId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])
  ledgerTransactions LedgerTransaction[]
  telegramObservations TelegramStarObservation[]
}

model LedgerAccount {
  id String @id @default(cuid())
  key String @unique
  organizationId String?
  currency String @default("XTR")
  kind String
  name String
  createdAt DateTime @default(now())
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  entries LedgerEntry[]
  @@index([organizationId, currency, kind])
}

model LedgerTransaction {
  id String @id @default(cuid())
  externalRef String @unique
  type String
  status String
  organizationId String?
  communityId String?
  paymentId String?
  grossAmount Int
  commissionBps Int
  metadata Json @default("{}")
  occurredAt DateTime @default(now())
  createdAt DateTime @default(now())
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  community Community? @relation(fields: [communityId], references: [id], onDelete: Restrict)
  payment PublicationPayment? @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  entries LedgerEntry[]
  @@index([organizationId, occurredAt])
  @@index([communityId, occurredAt])
  @@index([paymentId])
  @@index([type, status, occurredAt])
}

model LedgerEntry {
  id String @id @default(cuid())
  transactionId String
  accountId String
  amount Int
  createdAt DateTime @default(now())
  transaction LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  account LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  @@index([transactionId])
  @@index([accountId, createdAt])
}

model TelegramStarObservation {
  id String @id @default(cuid())
  fingerprint String @unique
  telegramTransactionId String
  amount Int
  nanostarAmount Int @default(0)
  direction String
  transactionDate DateTime
  partnerType String?
  invoicePayload String?
  paymentId String?
  raw Json
  observedAt DateTime @default(now())
  payment PublicationPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  @@index([telegramTransactionId])
  @@index([paymentId, transactionDate])
  @@index([direction, transactionDate])
}

model ListingImage {
  id String @id @default(cuid())
  listingId String
  storageProvider String
  storageKey String?
  telegramFileId String?
  telegramFileUniqueId String?
  url String?
  width Int?
  height Int?
  sizeBytes Int?
  sortOrder Int @default(0)
  createdAt DateTime @default(now())
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  @@index([listingId, sortOrder])
}

model Favorite {
  id String @id @default(cuid())
  userId String
  listingId String
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  @@unique([userId, listingId])
}

model ListingView {
  id String @id @default(cuid())
  userId String
  listingId String
  viewedAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  @@unique([userId, listingId])
}

model Report {
  id String @id @default(cuid())
  communityId String
  listingId String
  reporterId String
  reason String
  comment String?
  status ReportStatus @default(open)
  reviewedById String?
  reviewedAt DateTime?
  resolution String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  community Community @relation(fields: [communityId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])
  reporter User @relation("Reporter", fields: [reporterId], references: [id])
  reviewedBy User? @relation("ReportReviewer", fields: [reviewedById], references: [id])
  actions ModerationAction[]
  @@unique([listingId, reporterId, reason, status])
}

model ModerationAction {
  id String @id @default(cuid())
  communityId String
  moderatorId String
  targetUserId String?
  listingId String?
  reportId String?
  action String
  reason String?
  metadata Json?
  createdAt DateTime @default(now())
  community Community @relation(fields: [communityId], references: [id])
  moderator User @relation("Moderator", fields: [moderatorId], references: [id])
  targetUser User? @relation("TargetUser", fields: [targetUserId], references: [id])
  listing Listing? @relation(fields: [listingId], references: [id])
  report Report? @relation(fields: [reportId], references: [id])
  @@index([communityId, createdAt])
}

model Notification {
  id String @id @default(cuid())
  userId String?
  communityId String
  type String
  payload Json
  status NotificationStatus @default(pending)
  attempts Int @default(0)
  lastError String?
  createdAt DateTime @default(now())
  sentAt DateTime?
  user User? @relation(fields: [userId], references: [id])
  community Community @relation(fields: [communityId], references: [id])
  @@index([status, createdAt])
}
