NODE_ENV=development
APP_NAME=Community Board
APP_URL=http://localhost:8080
API_URL=http://localhost:8080/api
DEFAULT_LOCALE=ru
DEFAULT_TIMEZONE=Europe/Madrid
TELEGRAM_BOT_TOKEN=replace-with-bot-token
TELEGRAM_BOT_USERNAME=replace_with_bot_username
TELEGRAM_GROUP_ID=-1000000000000
TELEGRAM_GROUP_INVITE_URL=https://t.me/example
TELEGRAM_MINI_APP_URL=http://localhost:8080
TELEGRAM_MODERATION_CHAT_ID=
TELEGRAM_PUBLICATION_CHAT_ID=
TELEGRAM_PUBLICATION_THREAD_ID=
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=3600
MEMBERSHIP_CACHE_SECONDS=600
ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL_SECONDS=900
INITIAL_ADMIN_TELEGRAM_IDS=
DATABASE_URL=postgresql://board:board_dev_password@postgres:5432/board
REDIS_URL=redis://redis:6379
STORAGE_PROVIDER=local
UPLOAD_DIR=/app/uploads
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
MAX_LISTING_IMAGES=10
MAX_IMAGE_SIZE_MB=10
MAX_LISTING_TITLE_LENGTH=80
MAX_LISTING_DESCRIPTION_LENGTH=3000
MAX_ACTIVE_LISTINGS_PER_USER=10
LISTING_LIFETIME_DAYS=45
LISTING_EXPIRATION_WARNING_DAYS=3
AUTO_HIDE_REPORT_THRESHOLD=3
DAILY_DIGEST_ENABLED=false
DAILY_DIGEST_TIME=19:00
DAILY_DIGEST_TIMEZONE=Europe/Madrid
DAILY_DIGEST_MAX_LISTINGS=10
LOG_LEVEL=info
POSTGRES_USER=board
POSTGRES_PASSWORD=board_dev_password
POSTGRES_DB=board
